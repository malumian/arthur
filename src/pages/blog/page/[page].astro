---
import type {Page, PaginateFunction} from 'astro';
import {getCollection, type CollectionEntry} from 'astro:content';

import Blog from '@/layouts/Blog.astro';
import {BLOG_POSTS_PER_PAGE, PAGES_METADATA} from '@/consts';

type BlogPost = CollectionEntry<'blog'>;

interface Props {
  page: Page<BlogPost>;
}

export async function getStaticPaths({paginate}: {paginate: PaginateFunction}) {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  return paginate(posts, {pageSize: BLOG_POSTS_PER_PAGE}).filter(
    ({props}) => props.page.currentPage > 1,
  );
}

const {page} = Astro.props;
const posts = page.data;

const {title, description} = PAGES_METADATA.blog;
---

<Blog
  title={`${title} — Page ${page.currentPage}`}
  description={description}
  posts={posts}
  page={page}
/>
