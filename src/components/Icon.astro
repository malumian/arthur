---
type Props = {
  iconName: string;
  width?: string;
  height?: string;
  block?: boolean;
};

const {iconName, width = '2rem', height = '2rem', block = false} = Astro.props;
---

<svg
  style={{width, height, display: block ? 'block' : 'inline'}}
  aria-hidden='true'
>
  <use xlink:href={`#${iconName}`}></use>
</svg>
