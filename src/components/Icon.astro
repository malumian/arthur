---
type Props = {
  iconName: string;
  class?: string;
  width?: string;
  height?: string;
};

const {
  iconName,
  class: className,
  width = '30',
  height = '30',
  ...rest
} = Astro.props;
---

<svg
  class={className}
  width={`${width}px`}
  height={`${height}px`}
  aria-hidden='true'
  {...rest}
>
  <use xlink:href={`#${iconName}`}></use>
</svg>
