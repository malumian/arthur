---
import type {Page} from 'astro';

interface Props {
  page: Page;
}

const {
  page: {
    currentPage,
    lastPage,
    url: {first, last},
  },
} = Astro.props;

const range = 2;
const start = Math.max(1, currentPage - range);
const end = Math.min(lastPage, currentPage + range);
const pageNumbers = Array.from({length: end - start + 1}, (_, i) => start + i);

const getPageUrl = (pageNumber: number) => {
  return pageNumber === 1 ? '/blog/' : `/blog/page/${pageNumber}/`;
};
---

<nav aria-label='Pagination' class='pagination'>
  <div>
    {
      first ? (
        <a class='pagination-link' href={getPageUrl(1)}>
          First
        </a>
      ) : (
        <span aria-disabled='true' class='pagination-link is-disabled'>
          First
        </span>
      )
    }
  </div>
  <ol class='pagination-pages'>
    {
      pageNumbers.map((pageNumber) => (
        <li>
          <a
            aria-current={currentPage === pageNumber ? 'page' : undefined}
            class:list={[
              'pagination-link',
              'pagination-page',
              {active: currentPage === pageNumber},
            ]}
            href={getPageUrl(pageNumber)}
            tabindex={currentPage === pageNumber ? -1 : undefined}
          >
            {pageNumber}
          </a>
        </li>
      ))
    }
  </ol>
  <div>
    {
      last ? (
        <a class='pagination-link' href={getPageUrl(lastPage)}>
          Last
        </a>
      ) : (
        <span aria-disabled='true' class='pagination-link is-disabled'>
          Last
        </span>
      )
    }
  </div>
</nav>

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 2rem;
    font-family: var(--font-family-sans-serif-condensed);
    font-size: var(--font-size-medium);
    line-height: 1;
    text-align: center;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    justify-content: center;
    justify-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pagination-link {
    display: block;
    border: var(--border-small);
    color: var(--color-text-base);
    line-height: 1;
    padding: 0.75rem 1rem;
    text-decoration: none;
  }
  .pagination-link:hover {
    border-color: var(--color-primary-hover);
  }
  .pagination-link:active {
    border-color: var(--color-primary-active);
  }
  .pagination-link:focus-visible {
    border-color: var(--color-primary);
    outline: none;
  }
  .pagination-link.active {
    border-color: var(--color-primary);
  }
  .pagination-link.active:hover {
    border-color: var(--color-primary-hover);
  }
  .pagination-link.active:active {
    border-color: var(--color-primary-active);
  }
  .pagination-link.is-disabled {
    color: var(--color-text-secondary);
    cursor: not-allowed;
    border-color: var(--color-text-secondary);
  }
</style>
