---
interface Props {
  date: Date;
  class?: string;
}

const {date, class: className, ...rest} = Astro.props;
---

<time datetime={date.toISOString()} class={className} {...rest}>
  {
    date.toLocaleDateString('en-us', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  }
</time>
