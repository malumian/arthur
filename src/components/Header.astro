---
import HeaderLink from './HeaderLink.astro';

import {ROUTES} from '@/consts';
---

<header class='header'>
  <div class='wrapper'>
    <a href='/' class='logo'>
      <span class='logo-text'>Arthur</span>
      <span class='logo-text'>Malumian</span>
    </a>
    <nav class='nav'>
      <ul class='nav-list'>
        {
          ROUTES.map((route) => (
            <li class='nav-item'>
              <HeaderLink href={route.link}>{route.name}</HeaderLink>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: var(--border);
  }

  .wrapper {
    position: relative;
    margin: 0 auto;
    padding: 2rem;
    max-width: 760px;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .logo {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.4rem;
    font-family: var(--font-family-sans-serif-condensed);
    font-size: var(--font-size-default);
    line-height: var(--line-height-default);
    font-weight: bold;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-primary);
    user-select: none;
  }

  .logo:active {
    background-color: var(--color-primary-dark);
  }

  .logo-text {
    line-height: 1;
  }

  .nav-list {
    display: flex;
    margin: 0;
    font-family: var(--font-family-sans-serif-condensed);
    list-style: none;
    padding: 0;
    gap: 2rem;
    text-transform: uppercase;
    font-weight: bold;
  }

  @media only screen and (max-width: 500px) {
    .wrapper {
      justify-content: center;
      flex-direction: column;
      gap: 1rem;
    }
  }
</style>
