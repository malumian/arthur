---
import type {Page} from 'astro';
import {type CollectionEntry} from 'astro:content';

import Default from '@/layouts/Default.astro';
import FormattedDate from '@/components/FormattedDate.astro';
import {createExcerpt} from '@/utils/create-excerpt';
import {BLOG_POSTS_PER_PAGE} from '@/consts';

type BlogPost = CollectionEntry<'blog'>;

interface Props {
  title: string;
  description: string;
  posts: BlogPost[];
  page: Page<BlogPost>;
}

const {
  title,
  description,
  posts,
  page: {
    currentPage,
    lastPage,
    total,
    url: {first, last},
  },
} = Astro.props;

const range = 2;
const start = Math.max(1, currentPage - range);
const end = Math.min(lastPage, currentPage + range);
const pageNumbers = Array.from({length: end - start + 1}, (_, i) => start + i);

const getPageUrl = (pageNumber: number) => {
  return pageNumber === 1 ? '/blog/' : `/blog/page/${pageNumber}/`;
};
---

<Default title={title} description={description}>
  <section class='blog'>
    <h1>{title}</h1>
    <div class='posts-count'>
      {
        `Showing ${(currentPage - 1) * BLOG_POSTS_PER_PAGE + 1}–${Math.min(currentPage * BLOG_POSTS_PER_PAGE, total)} of ${total} posts`
      }
    </div>
    <div class='posts-list'>
      {
        posts.map((post: BlogPost) => {
          const excerpt = createExcerpt(post.body);

          return (
            <article>
              <a class='post-link' href={`/blog/${post.id}/`}>
                <h2 class='post-heading'>{post.data.title}</h2>
                <FormattedDate class='post-date' date={post.data.date} />
                <p class='post-excerpt'>{excerpt}</p>
              </a>
            </article>
          );
        })
      }
    </div>
    <nav aria-label='Pagination' class='pagination'>
      <div>
        {
          first ? (
            <a class='pagination-link' href={getPageUrl(1)}>
              First
            </a>
          ) : (
            <span aria-disabled='true' class='pagination-link is-disabled'>
              First
            </span>
          )
        }
      </div>
      <ol class='pagination-pages'>
        {
          pageNumbers.map((pageNumber) => (
            <li>
              <a
                aria-current={currentPage === pageNumber ? 'page' : undefined}
                class:list={[
                  'pagination-link',
                  'pagination-page',
                  {active: currentPage === pageNumber},
                ]}
                href={getPageUrl(pageNumber)}
                tabindex={currentPage === pageNumber ? -1 : undefined}
              >
                {pageNumber}
              </a>
            </li>
          ))
        }
      </ol>
      <div>
        {
          last ? (
            <a class='pagination-link' href={getPageUrl(lastPage)}>
              Last
            </a>
          ) : (
            <span aria-disabled='true' class='pagination-link is-disabled'>
              Last
            </span>
          )
        }
      </div>
    </nav>
  </section>
</Default>

<style>
  .blog {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .posts-count {
    margin: 2rem 0;
    line-height: 1;
    font-family: var(--font-family-sans-serif-condensed);
    font-size: var(--font-size-medium);
  }

  .posts-list {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    text-align: center;
  }

  .post-link {
    border: var(--border);
    padding: 2rem;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-text-base);
    gap: 0.5rem;
    font-family: var(--font-family-sans-serif-condensed);
  }
  .post-link:hover {
    border-color: var(--color-primary-hover);
  }
  .post-link:active {
    border-color: var(--color-primary-active);
  }
  .post-link:focus-within {
    outline: none;
    border-color: var(--color-primary);
  }

  .post-heading {
    margin: 0;
    font-size: var(--font-size-heading-3);
  }

  .post-date {
    color: var(--color-text-secondary);
  }

  .post-excerpt {
    font-family: var(--font-family-sans-serif);
    margin: 0;
    hyphens: none;
    text-align: left;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    margin: 2rem 0;
    font-family: var(--font-family-sans-serif-condensed);
    font-size: var(--font-size-medium);
    line-height: 1;
    text-align: center;
  }

  .pagination-pages {
    display: flex;
    align-items: center;
    justify-content: center;
    justify-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pagination-link {
    display: block;
    border: var(--border);
    color: var(--color-text-base);
    line-height: 1;
    padding: 0.75rem 1rem;
    text-decoration: none;
  }
  .pagination-link:hover {
    border-color: var(--color-primary-hover);
  }
  .pagination-link:active {
    border-color: var(--color-primary-active);
  }
  .pagination-link:focus-visible {
    border-color: var(--color-primary);
    outline: none;
  }
  .pagination-link.active {
    border-color: var(--color-primary);
  }
  .pagination-link.active:hover {
    border-color: var(--color-primary-hover);
  }
  .pagination-link.active:active {
    border-color: var(--color-primary-active);
  }
  .pagination-link.is-disabled {
    color: var(--color-text-secondary);
    cursor: not-allowed;
    border-color: var(--color-text-secondary);
  }
</style>
